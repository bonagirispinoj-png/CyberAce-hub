function analyseHealthRecord(){
  const text=document.getElementById('healthRecordInput').value.trim();
  if(!text||text.length<10){showToast('⚠ Enter your health report details');return;}
  const result=document.getElementById('healthRecordResult');
  result.style.display='block';
  // Simple pattern matching for common health values
  const bsMatch=text.match(/blood\s*sugar[:\s]*(\d+)/i);
  const cholMatch=text.match(/cholesterol[:\s]*(\d+)/i);
  const hbMatch=text.match(/h[ae]moglobin[:\s]*([\d.]+)/i);
  const bpMatch=text.match(/bp[:\s]*(\d+\/\d+)/i)||text.match(/blood\s*pressure[:\s]*(\d+\/\d+)/i);
  let analysis='<strong>📂 AI Health Record Analysis</strong><br><br>';
  if(bsMatch){
    const bs=parseInt(bsMatch[1]);
    analysis+=`🩸 <strong>Blood Sugar: ${bs} mg/dL</strong> — ${bs<100?'✅ Normal (fasting)':bs<126?'⚠️ Pre-diabetic range (100–125) — reduce sugar intake':' 🚨 Diabetic range (>126) — consult endocrinologist'}<br>`;
  }
  if(cholMatch){
    const ch=parseInt(cholMatch[1]);
    analysis+=`💛 <strong>Cholesterol: ${ch} mg/dL</strong> — ${ch<200?'✅ Normal':ch<240?'⚠️ Borderline high — reduce fried foods':' 🚨 High — medication may be needed, see doctor'}<br>`;
  }
  if(hbMatch){
    const hb=parseFloat(hbMatch[1]);
    analysis+=`❤️ <strong>Haemoglobin: ${hb} g/dL</strong> — ${hb>=12?'✅ Normal':hb>=10?'⚠️ Mild anaemia — increase iron-rich foods (spinach, beetroot)':'🚨 Severe anaemia — consult doctor immediately'}<br>`;
  }
  if(bpMatch){
    const bp=bpMatch[1];
    const[sys,dia]=bp.split('/').map(Number);
    analysis+=`🩺 <strong>BP: ${bp} mmHg</strong> — ${sys<120&&dia<80?'✅ Normal':sys<130?'⚠️ Elevated — reduce salt intake':' 🚨 High BP — medication and lifestyle change needed'}<br>`;
  }
  if(!bsMatch&&!cholMatch&&!hbMatch&&!bpMatch){
    analysis+=`<div style="font-size:.82rem;color:var(--txt3);line-height:1.8">
    Your report has been analysed. Please consult a doctor for detailed interpretation.<br><br>
    <strong>General Health Actions:</strong><br>
    ✅ Get annual complete blood count (CBC)<br>
    ✅ Check blood sugar every 6 months if family history<br>
    ✅ Lipid profile yearly after age 30<br>
    ✅ Blood pressure monitoring monthly
    </div>`;
  }
  analysis+='<br><em style="font-size:.72rem;color:var(--txt4)">⚕️ This is AI-assisted guidance only. Always consult a qualified doctor for medical decisions.</em>';
  result.innerHTML=analysis;
}


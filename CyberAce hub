          <div class="stat-sub">Goal: 8 glasses</div>
          <div class="progress-bar"><div class="pb-fill pb-water" id="pbWater" style="width:0%"></div></div>
        </div>
        <div class="stat-card sc-sleep">
          <div class="stat-v" id="statSleep">0h</div>
          <div class="stat-l">Sleep</div>
          <div class="stat-sub">Goal: 8 hours</div>
          <div class="progress-bar"><div class="pb-fill pb-sleep" id="pbSleep" style="width:0%"></div></div>
        </div>
        <div class="stat-card sc-hr">
          <div class="stat-v" id="statHR">72</div>
          <div class="stat-l">Heart Rate</div>
          <div class="stat-sub">BPM · Normal</div>
        </div>
      </div>
      <div class="sect-hd">Quick Log</div>
      <div class="card">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px">
          <input class="inp" type="number" id="inpWater" placeholder="Glasses water" style="margin-bottom:0"/>
          <input class="inp" type="number" id="inpSleep" placeholder="Hours sleep" style="margin-bottom:0"/>
          <input class="inp" type="number" id="inpHR" placeholder="Heart rate BPM" style="margin-bottom:0"/>
          <button class="btn btn-primary" onclick="saveLog()" style="margin-bottom:0">📊 Save Log</button>
        </div>
      </div>
      <div class="sect-hd">Mood Check-In</div>
      <div class="card">
        <div class="mood-row">
          <button class="mood-btn" onclick="setMood(this,'😄','Great')">😄</button>
          <button class="mood-btn" onclick="setMood(this,'😊','Good')">😊</button>
          <button class="mood-btn" onclick="setMood(this,'😐','Neutral')">😐</button>
          <button class="mood-btn" onclick="setMood(this,'😔','Low')">😔</button>
          <button class="mood-btn" onclick="setMood(this,'😤','Stressed')">😤</button>
          <button class="mood-btn" onclick="setMood(this,'😴','Tired')">😴</button>
        </div>
        <div style="font-size:.7rem;color:var(--txt4);text-align:center;margin-top:6px" id="moodStatus">Tap to log your mood</div>
      </div>
      <div class="sect-hd">Weekly Streak</div>
      <div class="card"><div style="display:flex;gap:6px;justify-content:center;flex-wrap:wrap;padding:8px 0" id="streakRow"></div></div>
    </div>
  </div>

  <!-- WELLNESS -->
  <div id="pgWellness" class="pg">
    <div class="wrap">
      <div class="sect-hd">🧘 Meditation Timer</div>
      <div class="card">
        <div style="text-align:center;padding:14px 0">

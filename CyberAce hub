  if(m>=5&&m<=8)return'Monsoon (Jun–Sep) — Humidity & infection risk';
  if(m>=9&&m<=10)return'Post-Monsoon (Oct–Nov) — Dengue alert season';
  return'Winter (Dec–Feb) — Respiratory health alert';
}

function getSeasonalFoods(){

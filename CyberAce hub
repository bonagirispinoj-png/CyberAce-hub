    }else{
      const myRef=genRef(user.displayName||'USER',user.uid);
      await db.collection('users').doc(user.uid).set({name:user.displayName||'User',email:user.email,refCode:myRef,referralCode:myRef,wallet:0,balance:0,bookPurchased:false,bookStatus:'none',streak:0,totalKm:0,todayKm:0,kmLimit:300,joinedAt:firebase.firestore.FieldValue.serverTimestamp()});

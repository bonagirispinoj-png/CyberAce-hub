    const d=snap.data();
    S.wallet=d.wallet||d.balance||0;S.totalKm=d.totalKm||0;S.todayKm=d.todayKm||0;S.kmLimit=d.kmLimit||300;S.bookPurchased=d.bookPurchased||false;S.bookStatus=d.bookStatus||'none';

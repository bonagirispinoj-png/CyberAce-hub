    if(logDoc.exists){const l=logDoc.data();S.water=l.water||0;S.sleep=l.sleep||0;S.hr=l.hr||72;S.mood=l.mood||'';}
  }catch(e){console.error('loadUser:',e);}

  db.collection('users').doc(user.uid).onSnapshot(snap=>{

  document.getElementById('bmiTips').innerHTML=`<div class="card" style="padding:12px">
    ${tips.map(t=>`<div style="display:flex;gap:8px;align-items:flex-start;padding:6px 0;border-bottom:1px solid var(--bdr);font-size:.82rem;color:var(--txt3)"><span style="color:var(--gold);flex-shrink:0">✦</span>${t}</div>`).join('')}

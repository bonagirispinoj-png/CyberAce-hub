async function loadTxns(uid){
  try{
    const[p,w]=await Promise.all([
      db.collection('payments').where('userId','==',uid).orderBy('submittedAt','desc').limit(10).get().catch(()=>({docs:[]})),
      db.collection('withdrawals').where('uid','==',uid).orderBy('time','desc').limit(10).get().catch(()=>({docs:[]}))
    ]);
    const list=document.getElementById('txnList');
    const items=[];
    p.docs.forEach(d=>{const t=d.data();items.push({type:'pay',desc:`Book Purchase`,amt:t.amount||1999,status:t.status,date:t.submittedAt?.toDate()});});
    w.docs.forEach(d=>{const t=d.data();items.push({type:'wd',desc:`Withdrawal → ${t.upiId||'UPI'}`,amt:t.amount||0,status:t.status,date:t.time?.toDate()});});
    if(!items.length){list.innerHTML='<div class="empty"><div class="empty-ico">📭</div><div class="empty-txt">No transactions yet</div></div>';return;}
    items.sort((a,b)=>(b.date||0)-(a.date||0));
    const sc=s=>s==='approved'||s==='paid'?'var(--green)':s==='rejected'?'var(--red)':'var(--amber)';
    list.innerHTML=items.map(t=>`<div class="txn-item"><div class="txn-ico ${t.type==='wd'?'txn-ico-out':'txn-ico-in'}">${t.type==='wd'?'💸':'💰'}</div><div class="txn-desc"><div>${san(t.desc)}</div><div style="color:${sc(t.status)};text-transform:uppercase;font-weight:700;font-size:.65rem">${t.status}</div></div><span class="${t.type==='wd'?'txn-out':'txn-in'}">${t.type==='wd'?'-':''}₹${t.amt}</span></div>`).join('');
  }catch(e){}
}

async function requestWithdraw(){
  if(!currentUser)return;
  if(!S.bookPurchased){showToast('⚠ Buy the book first to access withdrawals');return;}
  const amt=parseInt(document.getElementById('withdrawAmt').value);
  const upi=san(document.getElementById('withdrawUPI').value);
  if(!amt||amt<50){showToast('⚠ Minimum withdrawal is ₹50');return;}
  if(!upi||upi.length<5||!upi.includes('@')){showToast('⚠ Enter valid UPI ID (e.g. name@upi)');return;}
  const doc=await db.collection('users').doc(currentUser.uid).get();
  const bal=doc.data().wallet||doc.data().balance||0;
  if(bal<amt){showToast(`⚠ Insufficient balance. Available: ₹${bal.toFixed(0)}`);return;}
  try{
    await db.collection('withdrawals').add({uid:currentUser.uid,name:currentUser.displayName||'User',email:currentUser.email||'',amount:amt,upiId:upi,status:'pending',time:firebase.firestore.FieldValue.serverTimestamp()});
    await db.collection('users').doc(currentUser.uid).update({wallet:firebase.firestore.FieldValue.increment(-amt),balance:firebase.firestore.FieldValue.increment(-amt)});
    document.getElementById('withdrawAmt').value='';document.getElementById('withdrawUPI').value='';
    showToast(`✅ Withdrawal ₹${amt} requested! 1–3 days.`);
    loadTxns(currentUser.uid);
  }catch(e){showToast('⚠ Request failed');}
}


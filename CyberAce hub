<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no"/>
<meta name="theme-color" content="#0d2818"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
<meta name="apple-mobile-web-app-title" content="Health is Wealth"/>
<meta name="description" content="Health is Wealth — Complete AI Health + Wellness Platform"/>
<meta http-equiv="X-Content-Type-Options" content="nosniff"/>
<meta http-equiv="X-XSS-Protection" content="1; mode=block"/>
<title>Health is Wealth — Wellness Platform</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-auth-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-firestore-compat.js"></script>
<style>
:root{
  --forest:#0d2818;--forest2:#1a3d28;--forest3:#2d5a3d;--forest4:#3d7a52;
  --sage:#6b9e7a;--sage2:#8fbf9e;--sage3:#b8d9c2;
  --gold:#c9a84c;--gold2:#e8c87a;--gold3:#8a6820;
  --bg:#f5f0e6;--bg2:#ede8dc;--bg3:#e4dccf;
  --surf:#fff;--bdr:#d8ccb8;--bdr2:#c8bca8;
  --txt:#1a1208;--txt2:#3d3020;--txt3:#6b5c40;--txt4:#9e8c6e;
  --green:#1e6b3a;--green2:#d4edda;
  --red:#8b1a1a;--red2:#fde8e8;
  --amber:#8b5e00;--amber2:#fff8e6;
  --blue:#1e40af;--blue2:#dbeafe;
  --purple:#7c3aed;--purple2:#f5f3ff;
  --e1:0 1px 4px rgba(13,40,24,.06);--e2:0 4px 16px rgba(13,40,24,.1);
  --e3:0 10px 40px rgba(13,40,24,.14);--e4:0 20px 60px rgba(0,0,0,.22);
  --spring:cubic-bezier(.34,1.56,.64,1);--ease:cubic-bezier(.4,0,.2,1);
}
[data-theme="dark"]{
  --bg:#061210;--bg2:#0a1a12;--bg3:#0f2018;
  --surf:#0d1f14;--bdr:#1a3225;--bdr2:#254838;
  --txt:#e8f5ec;--txt2:#b8d9c2;--txt3:#7aab88;--txt4:#4a7058;
  --green2:#0d2a15;--red2:#2a0d0d;--amber2:#1a1200;--blue2:#0d1a2a;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;-webkit-font-smoothing:antialiased;}
html{height:100%;overflow-x:hidden;}
body{font-family:'Outfit',sans-serif;background:var(--bg);color:var(--txt);min-height:100vh;overflow-x:hidden;}
h1,h2,h3,h4{font-family:'Cormorant Garamond',Georgia,serif;}
button,input,select,textarea{font-family:'Outfit',sans-serif;}
::-webkit-scrollbar{width:4px;}
::-webkit-scrollbar-thumb{background:var(--sage3);border-radius:2px;}

/* SPLASH */
#splash{position:fixed;inset:0;z-index:9999;background:linear-gradient(160deg,#0d2818,#0a1f12,#051009);display:flex;flex-direction:column;align-items:center;justify-content:center;transition:opacity .8s,visibility .8s;}
#splash.gone{opacity:0;visibility:hidden;pointer-events:none;}
.sp-pulse{width:88px;height:88px;border-radius:50%;background:radial-gradient(circle,rgba(13,40,24,.9),rgba(5,15,10,.95));border:2px solid rgba(201,168,76,.3);display:flex;align-items:center;justify-content:center;font-size:2.4rem;margin-bottom:20px;animation:sp-pulse 2s ease infinite;}
@keyframes sp-pulse{0%,100%{box-shadow:0 0 0 0 rgba(201,168,76,.4);}50%{box-shadow:0 0 0 20px rgba(201,168,76,0);}}
.sp-name{font-family:'Cormorant Garamond',serif;font-size:1.9rem;color:#fff;font-weight:700;letter-spacing:2px;}
.sp-name span{color:var(--gold2);}
.sp-tag{font-size:.68rem;color:rgba(255,255,255,.35);letter-spacing:4px;text-transform:uppercase;margin-top:5px;}
.sp-bar{width:180px;height:2px;background:rgba(255,255,255,.08);border-radius:1px;margin-top:28px;overflow:hidden;}
.sp-fill{height:100%;background:linear-gradient(90deg,transparent,var(--gold2),transparent);animation:sp-fill 2.4s ease forwards;}
@keyframes sp-fill{from{transform:translateX(-100%);}to{transform:translateX(100%);}}

/* AUTH */
#authScreen{min-height:100vh;display:none;flex-direction:column;align-items:center;justify-content:center;background:linear-gradient(160deg,#0d2818,#142a1c,#0a1f12);padding:24px 20px;}
.auth-box{width:100%;max-width:380px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:22px;padding:28px 22px;backdrop-filter:blur(12px);}
.auth-logo{text-align:center;margin-bottom:20px;}
.auth-logo-ico{font-size:3rem;margin-bottom:8px;}
.auth-logo h1{font-family:'Cormorant Garamond',serif;font-size:1.9rem;font-weight:700;color:#fff;letter-spacing:2px;}
.auth-logo h1 span{color:var(--gold2);}
.auth-logo p{font-size:.68rem;color:rgba(255,255,255,.35);letter-spacing:3px;text-transform:uppercase;margin-top:4px;}
.auth-tabs{display:flex;background:rgba(0,0,0,.3);border-radius:10px;padding:3px;margin-bottom:20px;}
.auth-tab{flex:1;padding:9px;border:none;border-radius:8px;cursor:pointer;font-size:.8rem;font-weight:700;transition:.2s;background:transparent;color:rgba(255,255,255,.45);}
.auth-tab.on{background:var(--forest2);color:var(--gold2);}
.ai{width:100%;padding:12px 14px;margin-bottom:10px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:10px;color:#fff;font-size:.9rem;outline:none;transition:.2s;}
.ai:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(201,168,76,.12);}
.ai::placeholder{color:rgba(255,255,255,.3);}
.btn-gold{width:100%;padding:13px;border:none;border-radius:10px;cursor:pointer;background:linear-gradient(135deg,var(--gold3),var(--gold),var(--gold2));color:var(--forest);font-weight:800;font-size:.88rem;letter-spacing:.5px;box-shadow:0 4px 20px rgba(201,168,76,.35);transition:.2s;}
.btn-gold:hover{transform:translateY(-1px);}
.btn-gold:disabled{opacity:.5;cursor:not-allowed;transform:none;}
.auth-err{color:#ff8a8a;font-size:.76rem;text-align:center;min-height:18px;margin-top:6px;}
.auth-ok{color:#86efac;font-size:.76rem;text-align:center;}
.auth-forgot{text-align:right;margin-bottom:10px;}
.auth-forgot button{background:none;border:none;color:rgba(255,255,255,.4);font-size:.74rem;cursor:pointer;}

/* APP */
#userApp{display:none;min-height:100vh;padding-bottom:70px;}
.topbar{background:var(--forest);position:sticky;top:0;z-index:400;display:flex;align-items:center;justify-content:space-between;padding:12px 16px;box-shadow:0 2px 16px rgba(0,0,0,.3);}
.tb-brand{display:flex;align-items:center;gap:8px;cursor:pointer;}
.tb-ico{font-size:1.4rem;}
.tb-name{font-family:'Cormorant Garamond',serif;font-size:1.05rem;font-weight:700;color:#fff;}
.tb-name span{color:var(--gold2);}
.tb-right{display:flex;align-items:center;gap:6px;}
.tb-pill{background:rgba(201,168,76,.15);border:1px solid rgba(201,168,76,.3);color:var(--gold2);padding:4px 10px;border-radius:16px;font-size:.72rem;font-weight:700;cursor:pointer;border:none;}
.tb-theme{background:none;border:1px solid rgba(255,255,255,.15);color:rgba(255,255,255,.6);padding:5px 9px;border-radius:8px;cursor:pointer;font-size:.82rem;}
.tb-logout{background:none;border:1px solid rgba(255,255,255,.15);color:rgba(255,255,255,.5);padding:5px 10px;border-radius:8px;cursor:pointer;font-size:.72rem;}

/* NAV */
.bnav{position:fixed;bottom:0;left:0;right:0;z-index:400;background:var(--surf);border-top:1px solid var(--bdr);display:flex;padding-bottom:env(safe-area-inset-bottom);box-shadow:0 -4px 20px rgba(0,0,0,.08);}
.bn-item{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;padding:8px 2px;background:none;border:none;cursor:pointer;min-width:0;}
.bn-item.on{color:var(--forest);}
.bn-item:not(.on){color:var(--txt4);}
.bn-ico{font-size:1.1rem;line-height:1;}
.bn-lbl{font-size:.5rem;font-weight:700;letter-spacing:.2px;text-transform:uppercase;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:52px;}
.bn-item.on .bn-ico{transform:translateY(-2px);}

/* PAGES */
.pg{display:none;}.pg.on{display:block;}
.wrap{max-width:480px;margin:0 auto;padding:14px 14px 16px;}
.card{background:var(--surf);border:1px solid var(--bdr);border-radius:14px;padding:16px;box-shadow:var(--e1);margin-bottom:12px;}
.card-hd{font-family:'Cormorant Garamond',serif;font-size:1.05rem;font-weight:700;color:var(--txt);margin-bottom:12px;display:flex;align-items:center;gap:8px;}
.card-hd::before{content:'';width:3px;height:16px;background:linear-gradient(180deg,var(--gold),var(--sage));border-radius:2px;flex-shrink:0;}
.sect-hd{font-family:'Cormorant Garamond',serif;font-size:.72rem;color:var(--txt4);letter-spacing:2px;text-transform:uppercase;margin:16px 0 8px;display:flex;align-items:center;gap:8px;}
.sect-hd::after{content:'';flex:1;height:1px;background:var(--bdr);}

/* HERO */
.hero-banner{background:linear-gradient(135deg,var(--forest),var(--forest2),#1f4a2d);border-radius:18px;padding:22px 18px;margin-bottom:14px;position:relative;overflow:hidden;}
.hero-banner::before{content:'';position:absolute;right:-40px;top:-40px;width:160px;height:160px;border-radius:50%;background:radial-gradient(circle,rgba(201,168,76,.12),transparent);}
.hero-greeting{color:rgba(255,255,255,.55);font-size:.78rem;}
.hero-name{color:#fff;font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:700;margin:2px 0 12px;}
.hero-name span{color:var(--gold2);}
.hero-stats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;}
.hero-stat{background:rgba(255,255,255,.08);border-radius:10px;padding:9px;text-align:center;}
.hero-stat-v{font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:700;color:var(--gold2);}
.hero-stat-l{font-size:.58rem;color:rgba(255,255,255,.45);margin-top:2px;}

/* STATS */
.stat-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:12px;}
.stat-card{background:var(--surf);border:1px solid var(--bdr);border-radius:12px;padding:14px;box-shadow:var(--e1);position:relative;overflow:hidden;}
.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;border-radius:3px 3px 0 0;}
.sc-km::before{background:linear-gradient(90deg,var(--gold3),var(--gold));}
.sc-hr::before{background:linear-gradient(90deg,#c0392b,#e74c3c);}
.sc-sleep::before{background:linear-gradient(90deg,var(--purple),#9b59b6);}
.sc-water::before{background:linear-gradient(90deg,var(--blue),#3498db);}
.stat-v{font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-weight:700;color:var(--txt);line-height:1;}
.stat-l{font-size:.66rem;color:var(--txt4);margin-top:2px;letter-spacing:.5px;text-transform:uppercase;}
.stat-sub{font-size:.7rem;color:var(--txt3);margin-top:4px;}
.progress-bar{height:8px;background:var(--bg2);border-radius:4px;overflow:hidden;margin-top:6px;}
.pb-fill{height:100%;border-radius:4px;transition:width .6s var(--ease);}
.pb-km{background:linear-gradient(90deg,var(--gold3),var(--gold2));}
.pb-water{background:linear-gradient(90deg,var(--blue),#60a5fa);}
.pb-sleep{background:linear-gradient(90deg,var(--purple),#a78bfa);}

/* SCORE RING */
.score-wrap{display:flex;align-items:center;justify-content:center;gap:20px;padding:14px 0;}
.score-ring{position:relative;width:100px;height:100px;}
.score-ring svg{transform:rotate(-90deg);}
.score-ring-val{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;}
.score-num{font-family:'Cormorant Garamond',serif;font-size:1.8rem;font-weight:700;line-height:1;}
.score-lbl{font-size:.6rem;color:var(--txt4);letter-spacing:1px;}
.score-details{display:flex;flex-direction:column;gap:6px;}
.score-metric{display:flex;align-items:center;gap:8px;font-size:.8rem;}
.score-metric-ico{font-size:1rem;width:24px;}
.score-metric-val{font-weight:700;color:var(--txt2);margin-left:auto;}

/* GPS */
.gps-card{background:linear-gradient(135deg,var(--forest),var(--forest2));border-radius:18px;padding:20px;margin-bottom:14px;position:relative;overflow:hidden;}
.gps-dot{width:10px;height:10px;border-radius:50%;background:#4ade80;display:inline-block;animation:gps-blink 1.5s ease infinite;}
.gps-dot.off{background:#6b7280;animation:none;}
.gps-dot.waiting{background:var(--gold2);animation:gps-blink 1s ease infinite;}
@keyframes gps-blink{0%,100%{opacity:1;}50%{opacity:.3;}}
.gps-metrics{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin:12px 0;}
.gps-metric{background:rgba(255,255,255,.08);border-radius:10px;padding:10px;text-align:center;}
.gps-metric-v{font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:700;color:var(--gold2);}
.gps-metric-l{font-size:.58rem;color:rgba(255,255,255,.45);margin-top:2px;}
.gps-progress{background:rgba(255,255,255,.08);border-radius:8px;height:8px;margin-bottom:10px;overflow:hidden;}
.gps-progress-fill{height:100%;background:linear-gradient(90deg,var(--gold3),var(--gold2));border-radius:8px;transition:width .4s ease;}
.gps-btn-row{display:flex;gap:8px;}
.gps-btn{flex:1;padding:12px;border:none;border-radius:10px;cursor:pointer;font-size:.84rem;font-weight:700;display:flex;align-items:center;justify-content:center;gap:6px;}
.gps-start{background:linear-gradient(135deg,#16a34a,#22c55e);color:#fff;}
.gps-stop{background:linear-gradient(135deg,#c0392b,#e74c3c);color:#fff;}
.gps-pause{background:rgba(255,255,255,.15);color:#fff;border:1px solid rgba(255,255,255,.2);}
.locked-gps{background:rgba(255,255,255,.05);border:1px solid rgba(255,165,0,.3);border-radius:12px;padding:14px;text-align:center;margin-top:10px;}

/* MOOD */
.mood-row{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;padding:8px 0;}
.mood-btn{width:48px;height:48px;border-radius:50%;border:2px solid var(--bdr);background:var(--bg2);cursor:pointer;font-size:1.5rem;display:flex;align-items:center;justify-content:center;transition:.2s;}
.mood-btn.on{border-color:var(--gold);background:var(--amber2);transform:scale(1.1);}

/* MED TIMER */
.med-circle{width:120px;height:120px;border-radius:50%;border:4px solid var(--sage3);margin:12px auto;display:flex;align-items:center;justify-content:center;background:radial-gradient(circle,var(--green2),var(--bg));}
.med-circle.active{border-color:var(--forest);animation:med-breathe 4s ease infinite;}
@keyframes med-breathe{0%,100%{transform:scale(1);}50%{transform:scale(1.08);}}
.med-time-display{font-family:'Cormorant Garamond',serif;font-size:3rem;font-weight:700;color:var(--forest);letter-spacing:2px;text-align:center;}

/* BREATH */
.breath-circle{width:100px;height:100px;border-radius:50%;margin:0 auto 12px;display:flex;align-items:center;justify-content:center;font-size:.82rem;font-weight:700;color:#fff;transition:all 4s ease;background:radial-gradient(circle,var(--forest),var(--forest2));}
.breath-inhale{transform:scale(1.4);background:radial-gradient(circle,var(--forest4),var(--forest));}
.breath-hold{transform:scale(1.4);background:radial-gradient(circle,var(--gold),var(--gold3));}
.breath-exhale{transform:scale(1);background:radial-gradient(circle,var(--forest),#061210);}

/* ROUTINE */
.routine-item{display:flex;align-items:center;gap:12px;padding:10px 12px;background:var(--bg2);border-radius:10px;margin-bottom:7px;border-left:3px solid transparent;}
.ri-time{font-family:'Cormorant Garamond',serif;font-size:.88rem;font-weight:600;color:var(--forest);min-width:50px;}
.ri-ico{font-size:1.1rem;flex-shrink:0;}
.ri-text{font-size:.82rem;color:var(--txt2);flex:1;}
.ri-done{opacity:.5;text-decoration:line-through;}
.ri-now{border-left-color:var(--gold);background:var(--amber2);}

/* FIRST AID */
.firstaid-card{background:var(--surf);border:1px solid var(--bdr);border-radius:12px;margin-bottom:8px;overflow:hidden;cursor:pointer;}
.fa-header{padding:12px 14px;display:flex;align-items:center;gap:10px;}
.fa-ico{width:34px;height:34px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;}
.fa-title{font-size:.86rem;font-weight:700;color:var(--txt2);flex:1;}
.fa-arrow{color:var(--txt4);transition:.3s;}
.fa-arrow.open{transform:rotate(180deg);}
.fa-body{padding:0 14px 12px;font-size:.8rem;color:var(--txt3);line-height:1.6;display:none;}
.fa-body.open{display:block;}

/* SOS */
.sos-btn{width:100%;padding:18px;background:linear-gradient(135deg,#c0392b,#e74c3c);color:#fff;border:none;border-radius:14px;font-size:1.1rem;font-weight:800;cursor:pointer;animation:sos-pulse 1.5s infinite;display:flex;align-items:center;justify-content:center;gap:10px;}
@keyframes sos-pulse{0%,100%{box-shadow:0 4px 24px rgba(192,57,43,.4);}50%{box-shadow:0 4px 40px rgba(192,57,43,.7),0 0 0 10px rgba(192,57,43,.1);}}

/* ALERTS */
.alert-banner{border-radius:12px;padding:12px 14px;display:flex;align-items:flex-start;gap:10px;margin-bottom:10px;font-size:.82rem;line-height:1.5;}
.ab-info{background:linear-gradient(135deg,#dbeafe,#eff6ff);border:1px solid rgba(30,64,175,.2);color:#1e3a8a;}
.ab-success{background:linear-gradient(135deg,#dcfce7,#f0fdf4);border:1px solid rgba(22,101,52,.2);color:#14532d;}
.ab-warning{background:linear-gradient(135deg,#fde8e8,#fff5f5);border:1px solid rgba(192,57,43,.25);color:#7f1d1d;}
.ab-amber{background:var(--amber2);border:1px solid rgba(139,94,0,.2);color:var(--amber);}
.ab-ico{font-size:1.2rem;flex-shrink:0;margin-top:1px;}

/* BOOK */
.book-cover{background:linear-gradient(160deg,var(--forest),#1f4a2d,var(--forest2));border-radius:20px;padding:28px 20px;text-align:center;position:relative;overflow:hidden;margin-bottom:16px;box-shadow:var(--e3);}
.book-title{font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:700;color:#fff;line-height:1.3;margin-bottom:6px;}
.book-price{display:inline-block;background:linear-gradient(135deg,var(--gold3),var(--gold));color:var(--forest);padding:8px 22px;border-radius:20px;font-size:1.1rem;font-weight:800;font-family:'Cormorant Garamond',serif;}
.book-locked{background:var(--red2);border:1px solid rgba(139,26,26,.2);border-radius:10px;padding:14px;text-align:center;margin-bottom:12px;}
.book-unlocked{background:var(--green2);border:1px solid rgba(30,107,58,.2);border-radius:10px;padding:14px;text-align:center;margin-bottom:12px;}

/* UPI */
.upi-sheet{position:fixed;inset:0;z-index:800;background:rgba(0,0,0,.65);backdrop-filter:blur(6px);display:flex;align-items:flex-end;justify-content:center;opacity:0;visibility:hidden;transition:.3s;}
.upi-sheet.on{opacity:1;visibility:visible;}
.upi-content{background:var(--surf);border-radius:24px 24px 0 0;padding:24px 20px 36px;width:100%;max-width:480px;transform:translateY(100%);transition:.35s var(--spring);max-height:88vh;overflow-y:auto;}
.upi-sheet.on .upi-content{transform:translateY(0);}
.upi-handle{width:40px;height:4px;background:var(--bdr2);border-radius:2px;margin:0 auto 18px;}
.upi-step{background:var(--bg);border:1px solid var(--bdr);border-radius:12px;padding:14px;margin-bottom:12px;display:flex;align-items:flex-start;gap:12px;}
.upi-step-num{width:24px;height:24px;background:var(--forest);color:var(--gold2);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:800;flex-shrink:0;margin-top:1px;}
.upi-id-box{background:var(--forest);color:var(--gold2);padding:10px 16px;border-radius:10px;font-size:1rem;font-weight:800;letter-spacing:.5px;margin:8px 0;text-align:center;}
/* UPI App buttons - using intent/deep links */
.upi-btn{width:100%;padding:13px;border:none;border-radius:12px;cursor:pointer;font-size:.88rem;font-weight:700;margin-bottom:10px;display:flex;align-items:center;justify-content:center;gap:8px;text-decoration:none;}
.upi-gpay{background:linear-gradient(135deg,#4285f4,#3470dc);color:#fff;}
.upi-phone{background:linear-gradient(135deg,#7b2ff7,#5c1bd4);color:#fff;}
.upi-bhim{background:linear-gradient(135deg,#0066cc,#0052a3);color:#fff;}
.upi-other{background:var(--forest);color:var(--gold2);}
.upi-inp{width:100%;padding:12px 14px;border:2px solid var(--bdr);border-radius:10px;font-size:.9rem;outline:none;background:var(--bg);color:var(--txt);}
.upi-inp:focus{border-color:var(--forest);background:var(--surf);}

/* SUCCESS MODAL */
.success-modal{position:fixed;inset:0;z-index:900;background:rgba(0,0,0,.7);backdrop-filter:blur(8px);display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;visibility:hidden;transition:.3s;}
.success-modal.on{opacity:1;visibility:visible;}
.success-box{background:var(--surf);border-radius:24px;padding:32px 24px;width:100%;max-width:360px;text-align:center;box-shadow:var(--e4);animation:modal-in .4s var(--spring) both;}

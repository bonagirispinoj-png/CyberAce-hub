  document.getElementById('gpsEarned').textContent=`₹${Math.floor(S.wallet+gpsSessionKm)}`;
  const pct=Math.min(100,((S.totalKm+gpsSessionKm)/S.kmLimit)*100);
  document.getElementById('gpsProgressFill').style.width=pct+'%';
  document.getElementById('statKm').textContent=total.toFixed(2);
  document.getElementById('hKm').textContent=total.toFixed(2);
}


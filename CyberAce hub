function calcBMI(){
  const w=parseFloat(document.getElementById('bmiWeight').value);
  const h=parseFloat(document.getElementById('bmiHeight').value)/100;
  const age=parseInt(document.getElementById('bmiAge').value)||30;
  const gender=document.getElementById('bmiGender').value||'Male';
  if(!w||!h||w<10||h<0.5){showToast('⚠ Enter valid weight and height');return;}
  const bmi=w/(h*h);
  let cat,color,bg,advice,exercises,tips;
  if(bmi<18.5){
    cat='Underweight';color='#1e40af';bg='#dbeafe';
    advice=`Your BMI is ${bmi.toFixed(1)} — You are underweight. Ideal weight for your height (${(h*100).toFixed(0)} cm) is ${(18.5*h*h).toFixed(0)}–${(24.9*h*h).toFixed(0)} kg. Focus on calorie-dense nutritious foods.`;
    exercises=['🏋️ Light Weight Training — 3x/week to build muscle mass','🚶 Brisk Walking — 30 min daily to boost metabolism','🧘 Yoga — Improves appetite and digestive health','🏊 Swimming — Full body conditioning without joint stress'];
    tips=['Eat 5–6 small meals per day','Include nuts, seeds, ghee, paneer in diet','Drink milk + banana smoothie daily','Protein: 1.5g per kg body weight','Avoid drinking water before meals'];
  }else if(bmi<25){
    cat='Normal Weight';color='#1e6b3a';bg='#d4edda';
    advice=`Your BMI is ${bmi.toFixed(1)} — Excellent! You are at a healthy weight. Maintain with balanced diet and regular exercise. Ideal weight range: ${(18.5*h*h).toFixed(0)}–${(24.9*h*h).toFixed(0)} kg.`;
    exercises=['🏃 Running/Jogging — 30 min, 5x/week for cardio health','💪 Strength Training — 3x/week for muscle maintenance','🚴 Cycling — Great for heart and leg strength','🧘 Yoga/Stretching — For flexibility and mental health'];
    tips=['Maintain current eating habits','Stay hydrated: 8 glasses/day','Sleep 7–9 hours nightly','Regular health check-ups every 6 months','Limit processed foods and sugar'];
  }else if(bmi<30){
    cat='Overweight';color='#8b5e00';bg='#fff8e6';
    advice=`Your BMI is ${bmi.toFixed(1)} — You are overweight. Target weight for your height: ${(18.5*h*h).toFixed(0)}–${(24.9*h*h).toFixed(0)} kg. Need to lose ${(w-(24.9*h*h)).toFixed(0)} kg. Start with diet changes and daily walking.`;
    exercises=['🚶 Daily Walking — Start with 30 min, increase to 60 min','🏊 Swimming — Low impact, burns high calories','🚴 Cycling — Excellent for belly fat reduction','💃 Zumba/Dance — Fun way to burn 400-500 cal/hr'];
    tips=['Reduce refined carbs (white rice, maida, sugar)','Eat more vegetables and high-fiber foods','Avoid eating after 8 PM','Portion control — use smaller plates','Drink warm water with lemon in morning'];
  }else{
    cat='Obese';color='#8b1a1a';bg='#fde8e8';
    advice=`Your BMI is ${bmi.toFixed(1)} — Obesity risk zone. Please consult a doctor. Target weight: ${(18.5*h*h).toFixed(0)}–${(24.9*h*h).toFixed(0)} kg. Need to lose ${(w-(24.9*h*h)).toFixed(0)} kg. Health risks: diabetes, heart disease, joint pain.`;
    exercises=['🚶 Walking — Start slow, 15-20 min/day, gradually increase','🏊 Water Aerobics — Zero joint stress, high calorie burn','🧘 Chair Yoga — Safe for beginners with mobility issues','🚴 Stationary Bike — Controlled cardio exercise'];
    tips=['Consult a nutritionist immediately','Reduce sugar intake completely','Track every meal using a food diary','Join a weight loss support group','Intermittent fasting (consult doctor first)'];
  }
  document.getElementById('bmiResult').style.display='block';
  document.getElementById('bmiVal').textContent=bmi.toFixed(1);
  document.getElementById('bmiCat').textContent=cat;
  const resultBox=document.getElementById('bmiResultBox');
  resultBox.style.background=bg;resultBox.style.color=color;
  document.getElementById('bmiAdvice').textContent=advice;
  document.getElementById('bmiExercises').innerHTML=exercises.map(e=>`
    <div class="exercise-card">
      <div class="exercise-ico">${e.split(' ')[0]}</div>
